# Nest iOS 배포 레인.
#
# 인증: App Store Connect API 키(.p8) — 2FA 없는 완전 비대화식.
#   ios/fastlane/.env 에 설정 (.env.example 참고):
#     ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH, FASTLANE_TEAM_ID
#
# 레인:
#   fastlane ios build     — 서명된 릴리스 IPA 빌드만 (업로드 없음)
#   fastlane ios beta      — 빌드 + TestFlight 업로드
#   fastlane ios release   — 빌드 + 업로드 + 프로덕션 심사 제출(기존 메타데이터 재사용)
#   fastlane ios submit    — 이미 업로드된 빌드를 심사 제출만
#
# 버전은 pubspec.yaml의 `version: X.Y.Z+BUILD`를 그대로 쓴다.
# 스토어 업로드 전마다 BUILD를 올려야 한다 (docs/mobile_release.md §6).

default_platform(:ios)

FLUTTER_ROOT = File.expand_path("../..", __dir__)
BUNDLE_ID = "com.lionandthelab.nest"
EXPORT_OPTIONS = File.join(FLUTTER_ROOT, "ios", "ExportOptions.plist")

def asc_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
    duration: 1200,
    in_house: false,
  )
end

def pubspec_version
  # 로케일과 무관하게 UTF-8로 읽는다(pubspec에 한국어 주석 존재).
  version = File.read(File.join(FLUTTER_ROOT, "pubspec.yaml"), encoding: "UTF-8")[/^version:\s*(\S+)/, 1]
  UI.user_error!("pubspec.yaml에서 version을 읽지 못했습니다") if version.to_s.empty?
  name, build = version.split("+")
  [name, build.to_i]
end

# API 키로 App Store 배포 프로파일을 받아(없으면 포털에 생성) 수동 서명을
# 구성하고 릴리스 IPA를 빌드한다. 반환값: IPA 경로.
def flutter_build_ipa(api_key)
  get_provisioning_profile(
    api_key: api_key,
    app_identifier: BUNDLE_ID,
    platform: "ios",
    readonly: false,
    filename: "Nest_AppStore.mobileprovision",
  )
  profile_name = lane_context[SharedValues::SIGH_NAME]
  team = ENV.fetch("FASTLANE_TEAM_ID")

  update_code_signing_settings(
    use_automatic_signing: false,
    path: File.join(FLUTTER_ROOT, "ios", "Runner.xcodeproj"),
    team_id: team,
    targets: ["Runner"],
    code_sign_identity: "Apple Distribution",
    bundle_identifier: BUNDLE_ID,
    profile_name: profile_name,
  )

  File.write(EXPORT_OPTIONS, <<~PLIST)
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
      <key>method</key><string>app-store</string>
      <key>destination</key><string>export</string>
      <key>signingStyle</key><string>manual</string>
      <key>teamID</key><string>#{team}</string>
      <key>provisioningProfiles</key>
      <dict>
        <key>#{BUNDLE_ID}</key>
        <string>#{profile_name}</string>
      </dict>
      <key>uploadSymbols</key><true/>
      <key>stripSwiftSymbols</key><true/>
    </dict>
    </plist>
  PLIST

  Dir.chdir(FLUTTER_ROOT) do
    # fastlane의 Ruby 환경(GEM_HOME 등)이 flutter의 CocoaPods 검사를 깨뜨리므로
    # 관련 변수를 비우고 실행한다.
    sh("env", "-u", "RUBYOPT", "-u", "RUBYLIB", "-u", "GEM_HOME", "-u", "GEM_PATH",
       "-u", "BUNDLE_GEMFILE", "-u", "BUNDLE_BIN_PATH", "-u", "BUNDLE_PATH",
       "flutter", "build", "ipa", "--release",
       "--export-options-plist=#{EXPORT_OPTIONS}")
  end
  ipa = Dir.glob(File.join(FLUTTER_ROOT, "build", "ios", "ipa", "*.ipa"))
           .max_by { |f| File.mtime(f) }
  UI.user_error!("build/ios/ipa/ 아래에 IPA가 생성되지 않았습니다") unless ipa
  ipa
end

# 업로드 전에 pubspec 빌드 넘버가 TestFlight 최신보다 큰지 확인한다.
def assert_build_number_fresh!(api_key)
  _, build = pubspec_version
  latest = begin
    latest_testflight_build_number(api_key: api_key, app_identifier: BUNDLE_ID)
  rescue StandardError
    0
  end
  return if build > latest.to_i

  UI.user_error!(
    "pubspec version의 빌드 넘버(+#{build})가 TestFlight 최신 빌드(#{latest})보다 커야 " \
    "합니다. pubspec.yaml의 version을 올린 뒤 다시 실행하세요.",
  )
end

platform :ios do
  desc "스토어 상태 조회 (라이브 버전 / TestFlight 최신 빌드)"
  lane :status do
    api_key = asc_key
    version, build = pubspec_version
    tf = begin
      latest_testflight_build_number(api_key: api_key, app_identifier: BUNDLE_ID)
    rescue StandardError => e
      "조회 실패(#{e.message.lines.first&.strip})"
    end
    live = begin
      app_store_build_number(api_key: api_key, live: true, app_identifier: BUNDLE_ID)
      "#{lane_context[SharedValues::LATEST_VERSION]} (#{lane_context[SharedValues::LATEST_BUILD_NUMBER]})"
    rescue StandardError
      "라이브 버전 없음"
    end
    UI.important("pubspec: #{version}+#{build} | TestFlight 최신 빌드: #{tf} | App Store 라이브: #{live}")
  end

  desc "서명된 릴리스 IPA 빌드만 (업로드 없음)"
  lane :build do
    ipa = flutter_build_ipa(asc_key)
    UI.success("빌드 완료: #{ipa}")
  end

  desc "이미 빌드된 IPA를 TestFlight에 업로드만 (options: ipa)"
  lane :upload do |options|
    api_key = asc_key
    ipa = options[:ipa] ||
          Dir.glob(File.join(FLUTTER_ROOT, "build", "ios", "ipa", "*.ipa"))
             .max_by { |f| File.mtime(f) }
    UI.user_error!("build/ios/ipa/ 아래에 IPA가 없습니다 — 먼저 build 레인을 실행하세요") unless ipa
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true,
    )
    UI.success("TestFlight 업로드 완료: #{ipa}")
  end

  desc "빌드 + TestFlight 업로드"
  lane :beta do
    api_key = asc_key
    assert_build_number_fresh!(api_key)
    ipa = flutter_build_ipa(api_key)
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true,
    )
    version, build = pubspec_version
    UI.success("TestFlight 업로드 완료: #{version} (#{build})")
  end

  desc "빌드 + 업로드 + 프로덕션 심사 제출 (기존 메타데이터/스크린샷 재사용)"
  lane :release do
    api_key = asc_key
    assert_build_number_fresh!(api_key)
    ipa = flutter_build_ipa(api_key)
    version, build = pubspec_version
    upload_to_app_store(
      api_key: api_key,
      ipa: ipa,
      app_version: version,
      submit_for_review: true,
      automatic_release: true,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      force: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
      },
    )
    UI.success("프로덕션 심사 제출 완료: #{version} (#{build}) — 승인 시 자동 출시")
  end

  desc "이미 업로드된 빌드를 심사 제출만 (options: build)"
  lane :submit do |options|
    api_key = asc_key
    version, = pubspec_version
    upload_to_app_store(
      api_key: api_key,
      app_version: version,
      build_number: options[:build],
      submit_for_review: true,
      automatic_release: true,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      force: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
      },
    )
    UI.success("심사 제출 완료 — 승인 시 자동 출시")
  end
end
