# Environment & secrets
.env
.env.*
*.secret*.json
nest_client_secret_*.json
*client_secret*.json

# Firebase / OAuth 클라이언트 설정 (앱 번들 자산 · FCM 서비스계정) — git 미포함
# google-services.json / GoogleService-Info.plist 는 앱 빌드시 각 위치에 두되 커밋하지 않는다.
google-services*.json
GoogleService-Info*.plist
client_*.apps.googleusercontent.com.plist
*.apps.googleusercontent.com.json
*firebase-adminsdk*.json
*serviceaccount*.json
*service-account*.json
# Apple Sign In / APNs 인증 키 (.p8) — 시크릿, 절대 커밋 금지
*.p8
AuthKey_*.p8
# Google Cloud / Play 서비스 계정 키 (시크릿, 절대 커밋 금지)
nest-000-*.json
*-*.iam.gserviceaccount.com.json

# Supabase temp
supabase/.temp/

# Node
node_modules/

# OS
.DS_Store

# IDE / tools
.omc/

# One-off ops/debug scripts & render artifacts (kept local, not for history)
# NOTE: 메시징 서브모듈 파일(main_messaging_lab.dart, lion-notify,
#       run_messaging_lab.mjs, messaging_lab_smoke.mjs 등)은 여기서 무시하지
#       않는다 — 추후 별도 브랜치로 편입할 예정.
scripts/_*
scripts/*joy*
scripts/shots/
scripts/*.png
scripts/*.pdf
frontend/shots/

# Local data files (rosters, manuals, 출석부) — 원본 문서는 git에 넣지 않는다
/*.xlsx
/*.pdf
